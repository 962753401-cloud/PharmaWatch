# v2 行为检测系统配置
# 复制为 .env 后按需修改（v2 默认不依赖 API Key）

# YOLO-World 权重文件路径（默认在项目根目录 weights/ 下）
# 首次使用请从 https://github.com/ultralytics/ultralytics 下载 yolov8s-world.pt
WEIGHTS_PATH=../weights/yolov8s-world.pt

# 检测置信度阈值
CONF_PERSON=0.25
CONF_OBJECT=0.15

# 采样间隔（每 N 帧取 1 帧，30fps 视频 N=15 即 2fps）
SAMPLE_INTERVAL=15

# 触发器参数
CROWD_THRESHOLD=12
CROWD_CONSECUTIVE=3
CARRY_SUSTAIN_FRAMES=2
CARRY_EXPAND=50
LOITER_SECONDS=2.0
LOITER_RADIUS=80

# 切片参数（秒）
CLIP_HALF=5
CLIP_MAX=10
COOLDOWN=15

# 上传限制（MB）
MAX_UPLOAD_MB=800
