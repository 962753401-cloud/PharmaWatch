# 复制本文件为 .env 后填入真实 API Key（.env 不应提交到版本库）。
# DashScope API Key，见 ../qwen模型API.txt
DASHSCOPE_API_KEY=sk-your-key-here

# 可选：模型与 base_url（默认即北京区域 + qwen3-vl-plus）
QWEN_VL_MODEL=qwen3-vl-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 可选：抽帧 fps、超时、视频上限
QWEN_VL_FPS=2
QWEN_VL_TIMEOUT=120
MAX_VIDEO_MB=50